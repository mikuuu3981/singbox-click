{
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "type": "local",
        "tag": "singbox-click-local"
      }
    ]
  },
  "inbounds": [
    {
      "type": "anytls",
      "tag": "anytls-in",
      "listen": "::",
      "listen_port": 8443,
      "tcp_fast_open": true,
      "users": [
        {
          "name": "anytls-default",
          "password": "占位"
        }
      ],
      "tls": {
        "enabled": true,
        "certificate_path": "/etc/vless-reality/certs/server.crt",
        "key_path": "/etc/vless-reality/certs/server.key"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    },
    {
      "type": "direct",
      "tag": "direct-asis"
    },
    {
      "tag": "chain-JP-RADO-SS-prefer-ipv4",
      "type": "shadowsocks",
      "server": "占位",
      "server_port": 20632,
      "method": "aes-256-gcm",
      "password": "占位",
      "domain_resolver": {
        "server": "singbox-click-local",
        "strategy": "prefer_ipv4"
      }
    }
  ],
  "route": {
    "rules": [
      {
        "rule_set": [
          "geosite-youtube"
        ],
        "outbound": "direct-asis"
      },
      {
        "ip_cidr": [
          "126.206.65.15"
        ],
        "outbound": "direct-asis"
      },
      {
        "domain_suffix": [
          "speedtest.net"
        ],
        "outbound": "direct-asis"
      },
      {
        "rule_set": [
          "download"
        ],
        "outbound": "direct-asis"
      },
      {
        "outbound": "chain-JP-RADO-SS-prefer-ipv4"
      }
    ],
    "final": "direct",
    "rule_set": [
      {
        "type": "local",
        "tag": "geosite-youtube",
        "format": "binary",
        "path": "/etc/vless-reality/ruleset/geosite-youtube.srs"
      },
      {
        "type": "remote",
        "tag": "download",
        "format": "binary",
        "url": "https://ruleset.buluoai.top/singbox/download.srs"
      }
    ]
  }
}
